{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/dashboard", "destination": "/api/dashboard" },
    { "source": "/api/:path*", "destination": "/api/proxy?path=:path*" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
